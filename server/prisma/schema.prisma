generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  gender    String?
  dob       DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  cycles   Cycle[]
  symptoms Symptom[]
  chatLogs ChatLog[]
}

model Cycle {
  id        Int       @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime?
  flowLevel String?
  painLevel Int?
  notes     String?
  createdAt DateTime  @default(now())

  userId   Int
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptoms Symptom[]
}

model Symptom {
  id       Int      @id @default(autoincrement())
  date     DateTime
  mood     String?
  cramps   Boolean  @default(false)
  bloating Boolean  @default(false)
  headache Boolean  @default(false)
  fatigue  Boolean  @default(false)
  backPain Boolean  @default(false)
  notes    String?
  createdAt DateTime @default(now())

  userId  Int
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycleId Int?
  cycle   Cycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
}

model ChatLog {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}